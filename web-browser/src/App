import { Device } from "mediasoup-client";
import type {
  RtpCapabilities,
  Transport,
  TransportOptions,
} from "mediasoup-client/types";
import { useEffect, useRef } from "react";
import "./App.css";
import { SignalWebSocketClient } from "./hooks/SignalWebSocketClient";

const cctvList = Array.from({ length: 2 }, (_, i) => `video${i}`);

function App() {
  const deviceRef = useRef<Device | null>(null);
  const videoRefs = useRef<{ [key: string]: HTMLVideoElement | null }>({});
  const socketRef = useRef<SignalWebSocketClient | null>(null);
  const hubIdRef = useRef<string>("");
  const recvTransportRef = useRef<Transport | null>(null);
  const isConnectingRef = useRef<boolean>(false);

  useEffect(() => {
    connectWebSocket();
    return () => {
      if (socketRef.current) {
        socketRef.current.close();
      }
    };
  }, []);

  const connectWebRtc = async (ws: SignalWebSocketClient) => {
    hubIdRef.current = (
      (await ws.sendSync({
        type: "getLeastLoadedConsumerHub",
      })) as { hubId: string }
    ).hubId;

    const routerRtpCapabilities = (await ws.sendSync({
      type: "getRouterRtpCapabilities",
      payload: { hubId: hubIdRef.current },
    })) as RtpCapabilities;

    deviceRef.current = new Device();
    await deviceRef.current.load({
      routerRtpCapabilities: routerRtpCapabilities,
    });

    const webRtcTransport = (await ws.sendSync({
      type: "createWebRtcTransport",
      payload: { hubId: hubIdRef.current },
    })) as TransportOptions;

    recvTransportRef.current = deviceRef.current.createRecvTransport(
      webRtcTransport,
    ) as Transport;
    recvTransportRef.current.on(
      "connect",
      async ({ dtlsParameters }, callback) => {
        await ws.sendSync({
          type: "connectWebRtcTransport",
          payload: {
            hubId: hubIdRef.current,
            transportId: recvTransportRef.current!.id,
            dtlsParameters,
          },
        });
        callback();
      },
    );

    recvTransportRef.current.on("connectionstatechange", async (state) => {
      if (state === "disconnected") {
        recvTransportRef.current!.close();
        await connectWebRtc(ws);
        for (const videoId of cctvList) {
          consumeVideo(ws, videoId);
        }
      }
    });

    isConnectingRef.current = true;
  };

  const consumeVideo = async (ws: SignalWebSocketClient, videoId: string) => {
    const consumerInfo = (await ws.sendSync({
      type: "createConsumer",
      payload: {
        hubId: hubIdRef.current,
        videoId,
        transportId: recvTransportRef.current!.id,
        rtpCapabilities: deviceRef.current!.recvRtpCapabilities,
      },
    })) as {
      id: string;
      producerId: string;
      kind: "video";
      rtpParameters: any;
    };

    const consumer = await recvTransportRef.current!.consume({
      id: consumerInfo.id,
      producerId: consumerInfo.producerId,
      kind: consumerInfo.kind,
      rtpParameters: consumerInfo.rtpParameters,
    });

    const videoElement = videoRefs.current[videoId];
    if (videoElement) {
      const newStream = new MediaStream([consumer.track]);
      videoElement.srcObject = newStream;
      videoElement.play().catch(console.error);

      await ws.sendSync({
        type: "resumeConsumer",
        payload: {
          hubId: hubIdRef.current,
          transportId: recvTransportRef.current!.id,
          consumerId: consumer.id,
        },
      });
    }
  };

  const connectWebSocket = () => {
    const wsUrl = "ws://localhost:8080/signal";
    socketRef.current = new SignalWebSocketClient(wsUrl);

    socketRef.current.onopen = async () => {
      if (!isConnectingRef.current) {
        await connectWebRtc(socketRef.current!);
        for (const videoId of cctvList) {
          consumeVideo(socketRef.current!, videoId);
        }
      }
    };

    socketRef.current.onclose = async () => {
      setTimeout(() => {
        connectWebSocket();
      }, 3000);
    };

    socketRef.current.onerror = async () => {};
  };

  return (
    <div className="video-grid">
      {cctvList.map((cctvId) => (
        <video
          key={cctvId}
          ref={(el) => {
            videoRefs.current[cctvId] = el;
          }}
          autoPlay
          muted
          playsInline
          style={{ width: "200px", margin: "5px" }}
        />
      ))}
    </div>
  );
}

export default App;
